{
  "name": "diario-scuola-plus",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "cap:sync": "npm run build && npx cap sync",
    "cap:android": "npm run cap:sync && npx cap open android",
    "cap:ios": "npm run cap:sync && npx cap open ios",
    "deploy:vercel": "npm run build && npx vercel --prod",
    "deploy:preview": "npm run build && npx vercel",
    "assets:generate": "npx @capacitor/assets generate --iconBackgroundColor \"#2563eb\" --iconBackgroundColorDark \"#1e3a8a\" --splashBackgroundColor \"#2563eb\" --splashBackgroundColorDark \"#1e3a8a\"",
    "mobile:setup": "npm run build && npx cap add android && npx cap add ios && npm run assets:generate && npx cap sync",
    "screenshots:store": "node scripts/capture-appstore-screenshots.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^7.2.0",
    "@capacitor/app": "^7.0.1",
    "@capacitor/core": "^7.2.0",
    "@capacitor/filesystem": "^7.1.1",
    "@capacitor/haptics": "^7.0.1",
    "@capacitor/ios": "^7.2.0",
    "@capacitor/keyboard": "^7.0.1",
    "@capacitor/local-notifications": "^7.0.1",
    "@capacitor/share": "^7.0.1",
    "@capacitor/splash-screen": "^7.0.1",
    "@capacitor/status-bar": "^7.0.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.2.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "playwright": "^1.61.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-pwa": "^0.21.1"
  },
  "capacitor": {
    "appId": "com.diarioscuolaplus.app",
    "appName": "Diario Scuola Plus",
    "webDir": "dist"
  }
}
