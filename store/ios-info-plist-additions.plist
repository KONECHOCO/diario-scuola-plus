<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Aggiungi queste chiavi in ios/App/App/Info.plist dopo "npx cap add ios" su Mac.
  Oppure usa Xcode → Target → Info.
-->
<plist version="1.0">
<dict>
  <key>NSMicrophoneUsageDescription</key>
  <string>Diario Scuola Plus usa il microfono per registrare le tue lezioni audio.</string>
  <key>UIBackgroundModes</key>
  <array>
    <string>audio</string>
  </array>
  <key>ITSAppUsesNonExemptEncryption</key>
  <false/>
</dict>
</plist>
